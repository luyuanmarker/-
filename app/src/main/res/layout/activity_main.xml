<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- ==================== HEADER ==================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="⚔ 挑征事件编辑器"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#4C51BF" />
        </LinearLayout>

        <!-- ==================== FILE UPLOAD ==================== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:id="@+id/fileUploadArea"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="20dp"
                    android:minHeight="100dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📂"
                        android:textSize="36sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="上传JSON文件"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="点击选择JSON文件，自动解析并显示事件列表"
                        android:textSize="12sp"
                        android:textColor="#718096"
                        android:layout_marginTop="4dp" />

                    <Button
                        android:id="@+id/btnSelectFile"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginTop="10dp"
                        android:text="选择文件"
                        android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/fileInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvFileName"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="未选择文件"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#4C51BF" />

                        <TextView
                            android:id="@+id/tvEventCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0个事件"
                            android:textSize="12sp"
                            android:textColor="#FFFFFF"
                            android:background="#38a169"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="2dp" />
                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvEventList"
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:layout_marginTop="8dp" />

                    <!-- Event Details -->
                    <LinearLayout
                        android:id="@+id/eventDetails"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="12dp"
                        android:padding="12dp"
                        android:background="#F7FAFC"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="事件详情"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#4C51BF"
                            android:layout_marginBottom="8dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/detailId"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="事件ID: -"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/detailTrigger"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="触发类型: -"
                                android:textSize="13sp"
                                android:layout_marginTop="4dp" />

                            <TextView
                                android:id="@+id/detailTriggerValue"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="触发值: -"
                                android:textSize="13sp"
                                android:layout_marginTop="4dp" />

                            <TextView
                                android:id="@+id/detailChance"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="触发概率: -"
                                android:textSize="13sp"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>

                        <Button
                            android:id="@+id/btnLoadEvent"
                            android:layout_width="match_parent"
                            android:layout_height="36dp"
                            android:layout_marginTop="10dp"
                            android:text="加载到编辑器"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ==================== BASIC CONFIG ==================== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📋 基础配置"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#4C51BF" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#D0D0D0"
                    android:layout_marginTop="8dp" />

                <!-- Event ID + Conquer ID -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="事件ID"
                    android:textSize="13sp"
                    android:layout_marginTop="12dp"
                    android:textColor="#2D3748" />
                <EditText
                    android:id="@+id/etId"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:inputType="number"
                    android:text="101"
                    android:background="@drawable/edittext_bg"
                    android:paddingHorizontal="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="征服ID"
                    android:textSize="13sp"
                    android:layout_marginTop="8dp"
                    android:textColor="#2D3748" />
                <EditText
                    android:id="@+id/etConquerId"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:inputType="number"
                    android:text="1"
                    android:background="@drawable/edittext_bg"
                    android:paddingHorizontal="12dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ==================== EFFECT CONFIG ==================== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✨ 效果配置"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#4C51BF" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#D0D0D0"
                    android:layout_marginTop="8dp" />

                <!-- BUFF1 ID + Round1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="4dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="BUFF1 ID"
                            android:textSize="12sp"
                            android:textColor="#2D3748" />
                        <EditText
                            android:id="@+id/etEventBuffId1"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:inputType="number"
                            android:text="201"
                            android:background="@drawable/edittext_bg"
                            android:paddingHorizontal="12dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="持续回合"
                            android:textSize="12sp"
                            android:textColor="#2D3748" />
                        <EditText
                            android:id="@+id/etRound1"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:inputType="number"
                            android:text="5"
                            android:background="@drawable/edittext_bg"
                            android:paddingHorizontal="12dp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Country IDs for BUFF1 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="国家1 ID (逗号分隔)"
                    android:textSize="12sp"
                    android:layout_marginTop="8dp"
                    android:textColor="#2D3748" />
                <EditText
                    android:id="@+id/etCountryId1"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="1,2"
                    android:background="@drawable/edittext_bg"
                    android:paddingHorizontal="12dp" />

                <!-- BUFF2 ID + Round2 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BUFF2 ID (0表示无)"
                    android:textSize="12sp"
                    android:layout_marginTop="8dp"
                    android:textColor="#2D3748" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="4dp"
                        android:orientation="vertical">

                        <EditText
                            android:id="@+id/etEventBuffId2"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:inputType="number"
                            android:text="0"
                            android:background="@drawable/edittext_bg"
                            android:paddingHorizontal="12dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:orientation="vertical">

                        <EditText
                            android:id="@+id/etRound2"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:inputType="number"
                            android:text="0"
                            android:background="@drawable/edittext_bg"
                            android:paddingHorizontal="12dp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Country IDs for BUFF2 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="国家2 ID (逗号分隔)"
                    android:textSize="12sp"
                    android:layout_marginTop="8dp"
                    android:textColor="#2D3748" />
                <EditText
                    android:id="@+id/etCountryId2"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:background="@drawable/edittext_bg"
                    android:paddingHorizontal="12dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ==================== TRIGGER CONFIG ==================== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚡ 触发条件"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#4C51BF" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#D0D0D0"
                    android:layout_marginTop="8dp" />

                <!-- Trigger Type -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="触发类型"
                    android:textSize="13sp"
                    android:layout_marginTop="12dp"
                    android:textColor="#2D3748" />
                <EditText
                    android:id="@+id/etTrigger"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:inputType="number"
                    android:text="1"
                    android:background="@drawable/edittext_bg"
                    android:paddingHorizontal="12dp"
                    android:hint="1-回合 2-占领 3-攻击 4-空袭 5-连带 6-击败 7-核弹 8-城市 9-平分" />

                <!-- Trigger Value -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="触发值 (英文逗号分隔)"
                    android:textSize="12sp"
                    android:layout_marginTop="8dp"
                    android:textColor="#2D3748" />
                <EditText
                    android:id="@+id/etTriggerValueStr"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:background="@drawable/edittext_bg"
                    android:paddingHorizontal="12dp" />

                <!-- Location -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="发生地块 (逗号分隔)"
                    android:textSize="12sp"
                    android:layout_marginTop="8dp"
                    android:textColor="#2D3748" />
                <EditText
                    android:id="@+id/etLocation"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:background="@drawable/edittext_bg"
                    android:paddingHorizontal="12dp" />

                <!-- Chance -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="触发概率 (%)"
                    android:textSize="12sp"
                    android:layout_marginTop="8dp"
                    android:textColor="#2D3748" />
                <EditText
                    android:id="@+id/etChance"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:inputType="number"
                    android:text="100"
                    android:background="@drawable/edittext_bg"
                    android:paddingHorizontal="12dp" />

                <!-- Trigger Info -->
                <TextView
                    android:id="@+id/tvTriggerInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:padding="12dp"
                    android:background="#F7FAFC"
                    android:text="回合触发说明: 在 [n, m] 回合范围内每回合有概率触发事件"
                    android:textSize="12sp"
                    android:textColor="#4A5568" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ==================== TEMPLATES ==================== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📚 事件模板"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#4C51BF" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#D0D0D0"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="选择示例配置"
                    android:textSize="12sp"
                    android:layout_marginTop="10dp"
                    android:textColor="#2D3748" />
                <EditText
                    android:id="@+id/etTemplateSearch"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginTop="4dp"
                    android:hint="搜索模板... 回合/占领/攻击"
                    android:background="@drawable/edittext_bg"
                    android:paddingHorizontal="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="10dp"
                    android:gravity="center">

                    <Button
                        android:id="@+id/btnTemplateRound"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="36dp"
                        android:layout_marginEnd="4dp"
                        android:text="回合增益"
                        android:textSize="10sp"
                        android:backgroundTint="#4C51BF" />

                    <Button
                        android:id="@+id/btnTemplateConquer"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="36dp"
                        android:layout_marginHorizontal="4dp"
                        android:text="占领事件"
                        android:textSize="10sp"
                        android:backgroundTint="#38a169" />

                    <Button
                        android:id="@+id/btnTemplateAttack"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="36dp"
                        android:layout_marginHorizontal="4dp"
                        android:text="攻击触发"
                        android:textSize="10sp"
                        android:backgroundTint="#ED8936" />

                    <Button
                        android:id="@+id/btnTemplateGeneral"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="36dp"
                        android:layout_marginStart="4dp"
                        android:text="击败将领"
                        android:textSize="10sp"
                        android:backgroundTint="#E53E3E" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ==================== ACTION BUTTONS ==================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btnReset"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="🔄 重置表单"
                android:backgroundTint="#718096" />

            <Button
                android:id="@+id/btnGenerate"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="✅ 生成JSON"
                android:backgroundTint="#38a169" />
        </LinearLayout>

        <!-- ==================== OUTPUT ==================== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💻 事件配置JSON"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#4C51BF" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#D0D0D0"
                    android:layout_marginTop="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">

                    <Button
                        android:id="@+id/btnCopy"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="36dp"
                        android:layout_marginEnd="4dp"
                        android:text="📋 复制"
                        android:textSize="11sp" />

                    <Button
                        android:id="@+id/btnFormat"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="36dp"
                        android:layout_marginHorizontal="4dp"
                        android:text="格式化"
                        android:textSize="11sp" />

                    <Button
                        android:id="@+id/btnMinify"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="36dp"
                        android:layout_marginStart="4dp"
                        android:text="压缩"
                        android:textSize="11sp" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnExport"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginTop="8dp"
                    android:text="💾 导出为ConquerEventSettings.json"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvOutput"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_marginTop="8dp"
                    android:background="#F5F7FA"
                    android:padding="12dp"
                    android:text="// 配置完成后，JSON将显示在这里"
                    android:textSize="12sp"
                    android:typeface="monospace"
                    android:scrollbars="vertical" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ==================== FOOTER ==================== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="挑征事件编辑器 v2.0 | © 2025 乾隆开发 | 小辰科技"
            android:textSize="11sp"
            android:textColor="#718096"
            android:padding="16dp" />

    </LinearLayout>
</ScrollView>
